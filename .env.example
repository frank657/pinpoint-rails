# Copy to .env for local development (loaded by dotenv-rails). Never commit real secrets.

# --- App hosts (see docs/decisions/0006) ---
# Dev uses *.lvh.me which resolves to 127.0.0.1, so subdomain routing works locally:
#   landing  → http://lvh.me:3000
#   app      → http://app.lvh.me:3000
#   admin    → http://admin.lvh.me:3000
APP_DOMAIN=lvh.me:3000

# --- Database ---
# RAILS_MAX_THREADS=5
# PINPOINT_RAILS_DATABASE_PASSWORD=        # production only

# --- Redis (Sidekiq) ---
REDIS_URL=redis://localhost:6379/0

# --- Aliyun (Phase 2) ---
# These live in encrypted credentials (bin/rails credentials:edit), NOT in .env.
# Documented here so the required shape is discoverable:
#
#   aliyun:
#     access_key_id:        <oss + vod access key>
#     access_key_secret:    <secret>
#     bucket:               <oss bucket name>
#     endpoint:             oss-cn-shanghai.aliyuncs.com
#     vod:
#       endpoint:           vod.cn-shanghai.aliyuncs.com
#       api_version:        "2017-03-21"
#       storage_location:   <vod storage location>
#       video_template:     <transcode template group id>
#       callback_auth:      <shared secret for verifying VOD webhook signatures>
